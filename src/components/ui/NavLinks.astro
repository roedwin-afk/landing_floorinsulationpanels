---
import type { TranslationKeys } from '../../i18n/en';
import type { Lang } from '../../i18n/utils';

interface Props {
  t: TranslationKeys;
  lang: Lang;
  class?: string;
}

const { t, lang, class: className } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeHref = lang === 'es' ? `${base}es/` : base;

const techSpecsHref = lang === 'es' ? `${base}es/tech-specs` : `${base}tech-specs`;
const installation = lang === 'es' ? `${base}es/installation` : `${base}installation`;

const links = [
  { label: t.nav.features,     href: `${homeHref}#features` },
  { label: t.nav.techSpecs,    href: techSpecsHref           },
  { label: t.nav.installation, href: installation  },
  // { label: t.nav.specs,        href: `${homeHref}#specs`    },
];
---

<ul class={className}>
  {links.map(link => (
    <li><a href={link.href} class="navlink">{link.label}</a></li>
  ))}
</ul>

<style>
  ul {
    list-style: none;
    display: contents;
    font-weight: bold;
  }

  .navlink {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted-light);
    transition: color 0.2s;    
  }

  .navlink:hover {
    color: var(--color-accent);
  }
</style>