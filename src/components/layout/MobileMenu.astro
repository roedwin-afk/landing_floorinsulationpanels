---
import type { TranslationKeys } from '../../i18n/en';
import type { Lang } from '../../i18n/utils';
import { getAlternatePath } from '../../i18n/utils';
import NavLinks from '../ui/NavLinks.astro';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const contactHref    = lang === 'es' ? `${base}es/contact/` : `${base}contact/`;
const alternatePath  = getAlternatePath(Astro.url, base);
const alternateLabel = lang === 'es' ? 'EN' : 'ES';
---

<div class="mobile-menu" id="mobile-menu">
  <nav class="mobile-menu__nav">
    <NavLinks t={t} lang={lang} />
    <a href={contactHref} class="mobile-menu__cta">{t.nav.contact}</a>
    <a href={alternatePath} class="mobile-menu__lang">{alternateLabel}</a>
  </nav>
</div>

