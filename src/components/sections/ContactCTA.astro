---
import type { TranslationKeys } from '../../i18n/en';
import type { Lang } from '../../i18n/utils';
import { ArrowRight, Mail } from 'lucide-astro';
import ScrollReveal from '../ui/ScrollReveal.astro';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const contactHref = lang === 'es' ? `${base}es/contact/` : `${base}contact/`;
---

<section id="contact" class="cta">
  <div class="cta__inner">
    <ScrollReveal variant="fade-up" delay={1}>

    <div class="cta__card">
      <div class="cta__left">
        <span class="cta__badge">
          <Mail size={14} />
          {t.contact.badge}
        </span>
        <h2 class="cta__title">{t.contact.heading}</h2>
        <p class="cta__desc">{t.contact.subheading}</p>
      </div>

      <div class="cta__right">
        <a href={contactHref} class="cta__btn">
          {t.contact.cta}
          <ArrowRight size={18} />
        </a>
      </div>
    </div>
    </ScrollReveal>

  </div>
</section>

<style>
  .cta {
    padding: 6rem 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .cta__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .cta__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 3.5rem;
    position: relative;
    overflow: hidden;
  }

  .cta__card::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(37,99,235,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta__left {
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .cta__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.2);
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .cta__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .cta__desc {
    font-size: 1rem;
    color: var(--color-muted-light);
    max-width: 520px;
    line-height: 1.7;
  }

  .cta__right {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    background: var(--color-primary);
    color: #fff;
    padding: 1.1rem 2.5rem;
    border-radius: 8px;
    border: 1px solid var(--color-primary);
    transition: background 0.2s, transform 0.2s, gap 0.2s;
    white-space: nowrap;
  }

  .cta__btn:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    transform: translateY(-2px);
    gap: 1rem;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .cta__card {
      flex-direction: column;
      align-items: flex-start;
      padding: 2.5rem;
    }

    .cta__btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .cta { padding: 4rem 0; }
    .cta__card { padding: 2rem; }
  }
</style>