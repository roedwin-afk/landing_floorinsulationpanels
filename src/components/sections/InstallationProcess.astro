---
import type { TranslationKeys } from '../../i18n/en';
import type { Lang } from '../../i18n/utils';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;

const images = [
  'https://plus.unsplash.com/premium_photo-1682973055143-bb2aaf9cf7f2?q=80&w=1170&auto=format&fit=crop',
  'https://plus.unsplash.com/premium_photo-1674485300908-da4b93c84c13?q=80&w=1169&auto=format&fit=crop',
  'https://plus.unsplash.com/premium_photo-1664299732024-f0397c7da79a?q=80&w=1170&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1737874960921-d1205a4f55da?q=80&w=1170&auto=format&fit=crop',
];
---

<section id="process" class="process">
  <div class="process__inner">

    <div class="process__header">
      <div>
        <h2 class="process__title">{t.process.heading}</h2>
        <p class="process__sub">{t.process.subheading}</p>
      </div>
      <span class="process__badge">{t.process.badge}</span>
    </div>

    <div class="process__grid">
      {t.process.steps.map((step: { number: string; title: string; desc: string }, i: number) => (
        <article class="step-card">
          <div class="step-card__img-wrap">
            <img src={images[i]} alt={step.title} />
            <div class="step-card__img-overlay"></div>
          </div>
          <div class="step-card__body">
            <span class="step-card__number">{step.number}</span>
            <h4 class="step-card__title">{step.title}</h4>
            <p class="step-card__desc">{step.desc}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .process {
    padding: 6rem 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .process__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .process__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .process__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .process__sub {
    font-size: 0.95rem;
    color: var(--color-muted-light);
    max-width: 480px;
    line-height: 1.7;
  }

  .process__badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .step-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }

  .step-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
  }

  .step-card__img-wrap {
    position: relative;
    height: 160px;
    overflow: hidden;
  }

  .step-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    transition: opacity 0.4s, transform 0.5s;
  }

  .step-card:hover .step-card__img-wrap img {
    opacity: 0.8;
    transform: scale(1.05);
  }

  .step-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-bg) 0%, transparent 60%);
  }

  .step-card__body {
    padding: 1.25rem;
  }

  .step-card__number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .step-card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .step-card__desc {
    font-size: 0.825rem;
    color: var(--color-muted-light);
    line-height: 1.7;
  }

  /* ── Mobile ── */
  @media (max-width: 1024px) {
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .process__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .process__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .process { padding: 4rem 0; }
  }
</style>