---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Mail, Phone, MapPin } from "lucide-astro";
import ScrollReveal from "../ui/ScrollReveal.astro";

interface Props {
    t: TranslationKeys;
    lang: Lang;
}


const { t, lang } = Astro.props;

const site = import.meta.env.SITE ?? "https://roedwin-afk.github.io";
const base = import.meta.env.BASE_URL ?? "/landing_floorinsulationpanels/";
const thankYouPath = lang === "es" ? "es/thank-you" : "thank-you";
const thankYouUrl = `${site}${base}${thankYouPath}`;


---

<section class="contact" id="contact">
    <div class="contact__container">
        <!-- Info Panel -->
        <ScrollReveal variant="fade-right" delay={0}>
            <div class="contact__info">
                <p class="contact__eyebrow">{t.contactForm.eyebrow}</p>
                <h1 class="contact__title">{t.contactForm.title}</h1>
                <p class="contact__desc">{t.contactForm.description}</p>

                <div class="contact__data">
                    <a
                        href={`mailto:${t.contactForm.email}`}
                        class="contact__item"
                    >
                        <Mail size={19} />
                        <span>{t.contactForm.email}</span>
                    </a>
                    <a
                        href={`tel:${t.contactForm.phone}`}
                        class="contact__item"
                    >
                        <Phone size={19} />
                        <span>{t.contactForm.phone}</span>
                    </a>

                    <a
                        href="https://maps.google.com/?cid=15759084979067732314"
                        target="_blank"
                        rel="noopener"
                        class="contact__item"
                    >
                        <MapPin size={19} />
                        <span>{t.contactForm.address}</span>
                    </a>
                </div>

                <div class="contact__social">
                    <a
                        href="https://facebook.com"
                        target="_blank"
                        rel="noopener"
                        aria-label="Facebook"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://instagram.com"
                        target="_blank"
                        rel="noopener"
                        aria-label="Instagram"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect
                                x="2"
                                y="2"
                                width="20"
                                height="20"
                                rx="5"
                                ry="5"></rect>
                            <path
                                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                            ></path>
                            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                    </a>
                    <a
                        href="https://wa.me/525599903546"
                        target="_blank"
                        rel="noopener"
                        aria-label="WhatsApp"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"
                            ></path>
                        </svg>
                    </a>
                    <a
                        href="https://linkedin.com"
                        target="_blank"
                        rel="noopener"
                        aria-label="LinkedIn"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"
                            ></path>
                            <circle cx="4" cy="4" r="2"></circle>
                        </svg>
                    </a>
                </div>

                <div class="contact__map">
                    <div
                        id="contact-leaflet-map"
                        class="contact__map-canvas"
                        aria-label="Location map"
                    >
                    </div>
                </div>
            </div>
        </ScrollReveal>

        <!-- Zoho Form Panel -->
        <ScrollReveal variant="fade-left" delay={1}>
            <form
                class="contact__form"
                action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
                name="form"
                id="zoho-form"
                method="POST"
                accept-charset="UTF-8"
                enctype="multipart/form-data"
            >
                <input type="hidden" name="zf_referrer_name" value="" />
                <input
                    type="hidden"
                    name="zf_redirect_url"
                    value={thankYouUrl}
                />
                <input type="hidden" name="zc_gad" value="" />

                <div class="form__row">
                    <div class="form__group">
                        <label for="Name_First"
                            >{t.contactForm.fields.firstName}</label
                        >
                        <input
                            type="text"
                            maxlength="255"
                            name="Name_First"
                            id="Name_First"
                            placeholder={t.contactForm.fields.firstName}
                            required
                        />
                    </div>
                    <div class="form__group">
                        <label for="Name_Last"
                            >{t.contactForm.fields.lastName}</label
                        >
                        <input
                            type="text"
                            maxlength="255"
                            name="Name_Last"
                            id="Name_Last"
                            placeholder={t.contactForm.fields.lastName}
                            required
                        />
                    </div>
                </div>

                <div class="form__group">
                    <label for="Email">{t.contactForm.fields.email}</label>
                    <input
                        type="email"
                        name="Email"
                        id="Email"
                        maxlength="255"
                        placeholder={t.contactForm.fields.email_placeholder}
                        required
                    />
                </div>

                <div class="form__group">
                    <label for="PhoneNumber">{t.contactForm.fields.phone}</label
                    >
                    <input
                        type="tel"
                        name="PhoneNumber_countrycode"
                        id="PhoneNumber"
                        maxlength="20"
                        placeholder={t.contactForm.fields.phone_placeholder}
                    />
                </div>

                <div class="form__group">
                    <label for="MultiLine">{t.contactForm.fields.message}</label
                    >
                    <textarea
                        name="MultiLine"
                        id="MultiLine"
                        rows="14"
                        placeholder={t.contactForm.fields.message_placeholder}
                        required></textarea>
                </div>

                <button type="submit">{t.contactForm.submit}</button>
            </form>
        </ScrollReveal>
    </div>
</section>

<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>

<script is:inline>
    function initMap() {
        const mapContainer = document.getElementById("contact-leaflet-map");
        if (!mapContainer || !window.L) return;
        if (mapContainer._leaflet_id) return;

        const lat = 19.4326;
        const lng = -99.1946;

        const customIcon = window.L.icon({
            iconUrl:
                "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png",
            shadowUrl:
                "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
            iconSize: [25, 41],
            iconAnchor: [12, 41],
            popupAnchor: [1, -34],
            shadowSize: [41, 41],
        });

        const map = window.L.map("contact-leaflet-map").setView([lat, lng], 16);

        window.L.tileLayer(
            "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
            {
                attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
                subdomains: "abcd",
                maxZoom: 19,
            },
        ).addTo(map);

        window.L.marker([lat, lng], { icon: customIcon })
            .addTo(map)
            .bindPopup("Masaryk 61, Int. 901, Polanco V, 11560, CDMX")
            .openPopup();

        setTimeout(() => map.invalidateSize(), 200);
    }

    function waitForLeaflet() {
        if (window.L) {
            initMap();
        } else {
            setTimeout(waitForLeaflet, 100);
        }
    }

    document.addEventListener("astro:page-load", waitForLeaflet);
</script>

<style>
    .contact {
        padding: 6rem 2rem;
        background: var(--color-surface);
    }

    .contact__container {
        width: min(1200px, 100%);
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 2rem;
        align-items: stretch;
    }

    .contact__info,
    .contact__form {
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    }
    /* El div que genera ScrollReveal necesita height: 100% */
    .contact__container > div {
        display: contents;
        height: 100%;
    }

    .contact__form {
        height: 100%;
        box-sizing: border-box;
    }
    .contact__form textarea {
        resize: vertical;
        min-height: 200px;
    }

    .contact__eyebrow {
        margin: 0 0 0.75rem;
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--color-primary);
    }

    .contact__title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: var(--color-text);
    }

    .contact__desc {
        margin: 1rem 0 0;
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--color-muted-light);
    }

    .contact__data {
        display: grid;
        gap: 0.75rem;
        margin-top: 1.6rem;
    }

    .contact__item {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.9rem;
        border-radius: 10px;
        background: rgba(37, 99, 235, 0.05);
        border: 1px solid rgba(37, 99, 235, 0.12);
        color: var(--color-text);
        font-weight: 600;
        font-size: 0.9rem;
        line-height: 1.5;
        text-decoration: none;
        transition:
            background 0.2s,
            border-color 0.2s,
            transform 0.2s;
    }

    .contact__item:hover {
        transform: translateY(-2px);
        background: rgba(37, 99, 235, 0.1);
        border-color: rgba(37, 99, 235, 0.25);
    }

    .contact__item svg {
        flex-shrink: 0;
        margin-top: 0.15rem;
        color: var(--color-primary);
    }

    .contact__social {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.4rem;
    }

    .contact__social a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        text-decoration: none;
        transition:
            background 0.2s,
            border-color 0.2s,
            color 0.2s,
            transform 0.2s;
    }

    .contact__social a:hover {
        transform: translateY(-2px);
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: #fff;
    }

    .contact__map {
        margin-top: 1.4rem;
    }

    .contact__map-canvas {
        width: 100%;
        height: 240px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--color-border);
    }

    /* ── Form ── */
    .contact__form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        height: 100%;
    }

    .form__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form__group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form__group label {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-text);
    }

    .contact__form input,
    .contact__form textarea {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
        color: var(--color-text);
        font-family: var(--font-body);
        font-size: 0.95rem;
        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            background 0.2s;
        box-sizing: border-box;
    }

    .contact__form textarea {
        resize: vertical;
        min-height: 140px;
    }

    .contact__form input:focus,
    .contact__form textarea:focus {
        outline: none;
        border-color: var(--color-primary);
        background: var(--color-bg);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
    }

    .contact__form button {
        margin-top: 0.5rem;
        padding: 1rem 1.5rem;
        border: none;
        border-radius: 6px;
        background: var(--color-primary);
        color: #fff;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition:
            background 0.2s,
            transform 0.2s;
    }

    .contact__form button:hover {
        transform: translateY(-2px);
        background: var(--color-primary-dark, #1d4ed8);
    }
    .contact__form-wrapper {
        height: 100%;
    }

    /* ── Leaflet overrides ── */
    :global(.leaflet-popup-content-wrapper) {
        background: #1e293b !important;
        border: 1px solid rgba(37, 99, 235, 0.3);
        border-radius: 10px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    :global(.leaflet-popup-content) {
        color: #e2e8f0 !important;
        font-size: 0.85rem;
        font-weight: 600;
        margin: 10px 14px;
    }

    :global(.leaflet-popup-tip) {
        background: #1e293b !important;
    }

    :global(.leaflet-popup-close-button) {
        color: #64748b !important;
    }

    :global(.leaflet-control-zoom a) {
        background: #1e293b !important;
        color: #e2e8f0 !important;
        border-color: rgba(37, 99, 235, 0.3) !important;
    }

    :global(.leaflet-control-zoom a:hover) {
        background: #2563eb !important;
        color: #fff !important;
    }

    :global(.leaflet-control-attribution) {
        background: rgba(15, 23, 42, 0.8) !important;
        color: #475569 !important;
        font-size: 9px;
    }

    :global(.leaflet-control-attribution a) {
        color: #2563eb !important;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .contact__container {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 640px) {
        .contact {
            padding: 4rem 1.25rem;
        }

        .contact__info,
        .contact__form {
            padding: 1.5rem;
        }

        .form__row {
            grid-template-columns: 1fr;
        }

        .contact__map-canvas {
            height: 200px;
        }
    }
</style>
