---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Phone, Mail, MapPin } from "lucide-astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const site = import.meta.env.SITE ?? "https://roedwin-afk.github.io";
const base = import.meta.env.BASE_URL ?? "/landing_floorinsulationpanels/";
const thankYouPath = lang === "es" ? "es/thank-you" : "thank-you";
const thankYouUrl = `${site}${base}${thankYouPath}`;

const contactItems = [
  { icon: Phone, value: t.contactForm.phone },
  { icon: Mail, value: t.contactForm.email },
  { icon: MapPin, value: t.contactForm.address },
];
---

<section id="contact" class="contact">
  <div class="contact__inner">
    <!-- Left column -->
    <div class="contact__info">
      <span class="contact__eyebrow">{t.contactForm.eyebrow}</span>
      <h2 class="contact__title">{t.contactForm.title}</h2>
      <p class="contact__description">{t.contactForm.description}</p>

      <ul class="contact__list">
        {
          contactItems.map(({ icon: Icon, value }) => (
            <li class="contact__item">
              <div class="contact__icon">
                <Icon size={16} />
              </div>
              <p class="contact__item-value">{value}</p>
            </li>
          ))
        }
      </ul>

      <div class="contact__map">
        <div id="contact-leaflet-map" class="contact__map-canvas"></div>
      </div>
    </div>

    <!-- Right column -->
    <div class="contact__form-wrapper">
      <form
        class="contact__form"
        action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
        name="form"
        method="POST"
        accept-charset="UTF-8"
        enctype="multipart/form-data"
      >
        <input type="hidden" name="zf_referrer_name" value="" />
        <input type="hidden" name="zf_redirect_url" value={thankYouUrl} />
        <input type="hidden" name="zc_gad" value="" />

        <div class="form__row">
          <div class="form__group">
            <label class="form__label" for="Name_First"
              >{t.contactForm.fields.firstName}</label
            >
            <input
              id="Name_First"
              type="text"
              name="Name_First"
              maxlength="255"
              class="form__input"
              placeholder={t.contactForm.fields.firstName}
              required
            />
          </div>
          <div class="form__group">
            <label class="form__label" for="Name_Last"
              >{t.contactForm.fields.lastName}</label
            >
            <input
              id="Name_Last"
              type="text"
              name="Name_Last"
              maxlength="255"
              class="form__input"
              placeholder={t.contactForm.fields.lastName}
              required
            />
          </div>
        </div>

        <div class="form__group">
          <label class="form__label" for="Email"
            >{t.contactForm.fields.email}</label
          >
          <input
            id="Email"
            type="email"
            name="Email"
            maxlength="255"
            class="form__input"
            placeholder={t.contactForm.fields.email_placeholder}
            required
          />
        </div>

        <div class="form__group">
          <label class="form__label" for="PhoneNumber"
            >{t.contactForm.fields.phone}</label
          >
          <input
            id="PhoneNumber"
            type="tel"
            name="PhoneNumber_countrycode"
            maxlength="20"
            class="form__input"
            placeholder={t.contactForm.fields.phone_placeholder}
          />
        </div>

        <div class="form__group">
          <label class="form__label" for="MultiLine"
            >{t.contactForm.fields.message}</label
          >
          <textarea
            id="MultiLine"
            name="MultiLine"
            rows="18"
            class="form__input form__textarea"
            placeholder={t.contactForm.fields.message_placeholder}
            required></textarea>
        </div>

        <button type="submit" class="form__submit"
          >{t.contactForm.submit}</button
        >
      </form>
    </div>
  </div>
</section>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>

<script is:inline>
  function initMap() {
    const mapContainer = document.getElementById("contact-leaflet-map");
    if (!mapContainer || !window.L) return;
    if (mapContainer._leaflet_id) return;

    const lat = 19.4326;
    const lng = -99.1946;

    const customIcon = window.L.icon({
      iconUrl:
        "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png",
      shadowUrl:
        "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      shadowSize: [41, 41],
    });

    const isTouchDevice =
      "ontouchstart" in window || navigator.maxTouchPoints > 0;

    const map = window.L.map("contact-leaflet-map", {
      zoomControl: false,
      scrollWheelZoom: false,
      dragging: !isTouchDevice,
      tap: false,
    }).setView([lat, lng], 16);

    if (isTouchDevice) {
      const overlay = document.createElement("div");
      overlay.className = "map-touch-overlay";
      overlay.innerHTML = `<span>Usa dos dedos para mover el mapa</span>`;
      mapContainer.style.position = "relative";
      mapContainer.appendChild(overlay);

      mapContainer.addEventListener(
        "touchstart",
        () => {
          overlay.classList.add("is-hidden");
          map.dragging.enable();
        },
        { once: true },
      );
    }

    window.L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
      {
        attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: "abcd",
        maxZoom: 19,
      },
    ).addTo(map);

    window.L.marker([lat, lng], { icon: customIcon })
      .addTo(map)
      .bindPopup("Masaryk 61, Int. 901, Polanco V, 11560, CDMX")
      .openPopup();

    setTimeout(() => map.invalidateSize(), 200);
  }

  function waitForLeaflet() {
    if (window.L) {
      initMap();
    } else {
      setTimeout(waitForLeaflet, 100);
    }
  }

  document.addEventListener("astro:page-load", waitForLeaflet);
</script>

<style>
  .contact {
    padding: 8rem 1.5rem;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .contact__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 1024px) {
    .contact__inner {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* ── Left column ── */
  .contact__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    border-bottom: 1px solid rgba(56, 189, 248, 0.3);
    padding-bottom: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .contact__description {
    font-size: 0.95rem;
    color: var(--color-muted-light);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 420px;
  }

  .contact__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .contact__item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.2);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact__item-value {
    font-size: 0.9rem;
    color: var(--color-muted-light);
    line-height: 1.5;
  }

  /* ── Map ── */
  .contact__map {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .contact__map-canvas {
    width: 100%;
    height: 255px;
  }

  /* ── Right column ── */
  .contact__form-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: 16px;
    padding: 2.5rem;
    height: 100%;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 480px) {
    .form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  .form__input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text);
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .form__input::placeholder {
    color: var(--color-muted);
  }

  .form__input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.08);
  }

  .form__textarea {
    resize: vertical;
    min-height: 130px;
  }

  .form__submit {
    width: 100%;
    padding: 0.9rem 1rem;
    background: var(--color-accent);
    color: #0a0f1a;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .form__submit:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
</style>
