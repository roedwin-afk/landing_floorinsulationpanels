---
import type { TranslationKeys } from '../../i18n/en';
import type { Lang } from '../../i18n/utils';

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const contactHref = lang === 'es' ? `${base}es/contact/` : `${base}contact/`;
---

<section id="specs" class="specs">
  <div class="specs__inner">

    <div class="specs__grid">

      <div class="specs__table-wrap">
        <h2 class="specs__title">{t.specs.heading}</h2>
        <div class="specs__table">
          {t.specs.rows.map((row: { label: string; value: string }) => (
            <div class="specs__row">
              <span class="specs__label">{row.label}</span>
              <span class="specs__value">{row.value}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="specs__cta">
        <div class="specs__cta-inner">
          <span class="specs__cta-icon">⬡</span>
          <h3 class="specs__cta-title">{t.specs.cta.title}</h3>
          <p class="specs__cta-desc">{t.specs.cta.desc}</p>
          <a href={contactHref} class="specs__cta-btn">{t.specs.cta.button}</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .specs {
    padding: 6rem 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .specs__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .specs__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Table */
  .specs__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: 2rem;
  }

  .specs__table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
  }

  .specs__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s;
    gap: 1rem;
  }

  .specs__row:last-child {
    border-bottom: none;
  }

  .specs__row:hover {
    background: var(--color-surface);
  }

  .specs__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-light);
  }

  .specs__value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    text-align: right;
  }

  /* CTA Card */
  .specs__cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1d4ed8 100%);
    border-radius: 24px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .specs__cta::before {
    content: '⬡';
    position: absolute;
    bottom: -2rem;
    right: -1rem;
    font-size: 10rem;
    color: rgba(255,255,255,0.05);
    line-height: 1;
  }

  .specs__cta-inner {
    position: relative;
    z-index: 1;
  }

  .specs__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 12px;
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .specs__cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .specs__cta-desc {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .specs__cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: #fff;
    color: var(--color-primary);
    padding: 0.9rem 2rem;
    border-radius: 4px;
    font-weight: 700;
    transition: background 0.2s, transform 0.2s;
  }

  .specs__cta-btn:hover {
    background: #f1f5f9;
    transform: translateY(-2px);
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .specs__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .specs { padding: 4rem 0; }
    .specs__cta { padding: 2rem; }

    .specs__row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .specs__value {
      text-align: left;
      color: var(--color-accent);
    }
  }
</style>