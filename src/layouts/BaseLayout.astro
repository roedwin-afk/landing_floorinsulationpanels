---
import type { TranslationKeys } from "../i18n/en";
import type { Lang } from "../i18n/utils";
import Navbar from "../components/layout/Navbar.astro";
import Footer from '../components/layout/Footer.astro';
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  t: TranslationKeys;
  lang: Lang;
}

const {
  title,
  description = "High-density floor insulation panel systems for industrial and cold storage applications.",
  t,
  lang,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Floor Insulation Panels`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <meta
      property="og:image"
      content={new URL(`${import.meta.env.BASE_URL}og-image.png`, Astro.url)
        .href}
    />
    <meta
      name="twitter:image"
      content={new URL(`${import.meta.env.BASE_URL}og-image.png`, Astro.url)
        .href}
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Floor Insulation Panels`} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Alternate language -->
    <link
      rel="alternate"
      hreflang="en"
      href={`https://floorinsulationpanels.com/`}
    />
    <link
      rel="alternate"
      hreflang="es"
      href={`https://floorinsulationpanels.com/es/`}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={`https://floorinsulationpanels.com/`}
    />

    <title>{title} | Floor Insulation Panels</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600&family=Barlow+Condensed:wght@700;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <Navbar t={t} lang={lang} />
    <slot />
    <Footer t={t} lang={lang} />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #0f0f0f;
    --color-surface: #1c1c1c;
    --color-border: #2e2e2e;
    --color-accent: #e5e5e5; /* blanco roto como accent */
    --color-text: #f5f5f5;
    --color-muted: #666666;
    --color-muted-light: #999999;

    --font-display: "DM Sans", sans-serif;
    --font-body: "Inter", sans-serif;
    --font-mono: "IBM Plex Mono", monospace;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ─── Scroll Reveal ─────────────────────────────── */
  .reveal {
    opacity: 0;
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .reveal.fade-up {
    transform: translateY(28px);
  }
  .reveal.fade-down {
    transform: translateY(-28px);
  }
  .reveal.fade-left {
    transform: translateX(-28px);
  }
  .reveal.fade-right {
    transform: translateX(28px);
  }
  .reveal.fade-in {
    transform: none;
  }

  .reveal-delay-1 {
    transition-delay: 150ms;
  }
  .reveal-delay-2 {
    transition-delay: 300ms;
  }
  .reveal-delay-3 {
    transition-delay: 450ms;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translate(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
