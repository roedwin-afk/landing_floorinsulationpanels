---
import type { TranslationKeys } from "../i18n/en";
import type { Lang } from "../i18n/utils";
import Navbar from "../components/layout/Navbar.astro";
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  t: TranslationKeys;
  lang: Lang;
}

const {
  title,
  description = "High-density floor insulation panel systems for industrial and cold storage applications.",
  t,
  lang,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Floor Insulation Panels`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Floor Insulation Panels`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Alternate language -->
    <link
      rel="alternate"
      hreflang="en"
      href={`https://floorinsulationpanels.com/`}
    />
    <link
      rel="alternate"
      hreflang="es"
      href={`https://floorinsulationpanels.com/es/`}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={`https://floorinsulationpanels.com/`}
    />

    <title>{title} | Floor Insulation Panels</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600&family=Barlow+Condensed:wght@700;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <Navbar t={t} lang={lang} />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #0a0f1a;
    --color-surface: #111827;
    --color-border: #1e2d42;
    --color-primary: #2563eb;
    --color-primary-hover: #1d4ed8;
    --color-accent: #38bdf8;
    --color-text: #f1f5f9;
    --color-muted: #64748b;
    --color-muted-light: #94a3b8;

    --font-display: "Barlow Condensed", sans-serif;
    --font-body: "Barlow", sans-serif;
    --font-mono: "JetBrains Mono", monospace;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 {
    transition-delay: 0.1s;
  }
  .reveal-delay-2 {
    transition-delay: 0.2s;
  }
  .reveal-delay-3 {
    transition-delay: 0.3s;
  }
</style>
