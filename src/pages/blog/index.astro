---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import BlogList from "../../components/sections/BlogList.astro";
import { MOCK_POSTS } from "../../data/posts";
import { getLang, useTranslations } from '../../i18n/utils';

const locale = Astro.currentLocale ?? 'en';

const POSTS_PER_PAGE = 5;
const allPosts = MOCK_POSTS;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const base = import.meta.env.BASE_URL;

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<BaseLayout 
  title="Industrial Floor Insulation"
  description="High-density floor insulation panel systems for industrial warehouses and cold storage facilities."
  t={t} 
  lang={lang}
>
  <Navbar t={t} lang={lang} />
  <BlogList
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    basePath={`${base}blog/page/`}
    t={t}
    locale={locale}
  />
  <Footer t={t} lang={lang}/>
</BaseLayout>