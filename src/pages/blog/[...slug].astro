---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";
import { MOCK_POSTS } from "../../data/posts";

import { en } from "../../i18n/en";
import { es } from "../../i18n/es";

const locale = Astro.currentLocale ?? "en";
const t = locale === "es" ? es : en;
const lang = locale === "es" ? "es" : "en";

export async function getStaticPaths() {
  return MOCK_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}
// export async function getStaticPaths() {
//   const response = await fetch(`${import.meta.env.WORDPRESS_API_URL}/posts?_embed&per_page=100`);
//   const posts = await response.json();
//
//   return posts.map((post: any) => ({
//     params: { slug: post.slug },
//     props: { post },
//   }));
// }

const { post } = Astro.props as { post: any };
---

<BaseLayout
  title="Industrial Floor Insulation"
  description="High-density floor insulation panel systems for industrial warehouses and cold storage facilities."
  t={t}
  lang={lang}
>
  <Navbar t={t} lang={lang} />

  <main class="post">

    <div class="post__hero">
      <div class="post__hero-inner">
        <span class="post__tag">Technical Article</span>
        <h1 class="post__title" set:html={post.title.rendered} />
        <p class="post__date">
          {new Date(post.date).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
      </div>
    </div>

    {post._embedded?.["wp:featuredmedia"]?.[0]?.source_url && (
      <div class="post__image-wrap">
        <img
          src={post._embedded["wp:featuredmedia"][0].source_url}
          alt={post.title.rendered}
          class="post__image"
        />
      </div>
    )}

    <div class="post__body">

      <aside class="post__sidebar">
        <div class="sidebar__block">
          <p class="sidebar__label">Published</p>
          <p class="sidebar__value">
            {new Date(post.date).toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            })}
          </p>
        </div>

        <div class="sidebar__block">
          <p class="sidebar__label">Category</p>
          <p class="sidebar__value">Floor Insulation</p>
        </div>

        <div class="sidebar__block">
          <p class="sidebar__label">Reading time</p>
          <p class="sidebar__value">~5 min</p>
        </div>

        <div class="sidebar__divider" />

        <a href="/blog" class="sidebar__back">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.5 2.5L4 7L8.5 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to blog
        </a>
      </aside>

      <article class="post__content" set:html={post.content.rendered} />

    </div>
  </main>

  <Footer t={t} lang={lang} />
</BaseLayout>

<style>
  .post {
    background-color: var(--color-bg);
    font-family: var(--font-body);
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .post__hero {
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 2rem 3rem;
  }

  .post__hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .post__tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    padding: 0.2rem 0.65rem;
    margin-bottom: 1.5rem;
  }

  .post__title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    max-width: 820px;
  }

  .post__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }

  .post__image-wrap {
    max-width: 1100px;
    margin: 2.5rem auto;
    padding: 0 2rem;
  }

  .post__image {
    width: 100%;
    height: min(55vw, 500px);
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    display: block;
  }

  .post__body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .post__sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar__block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }

  .sidebar__value {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-muted-light);
    margin: 0;
  }

  .sidebar__divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.5rem 0;
  }

  .sidebar__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.15s;
  }

  .sidebar__back:hover {
    color: var(--color-accent);
  }

  .post__content {
    color: var(--color-muted-light);
    line-height: 1.85;
    font-size: 1rem;
    font-family: var(--font-body);
    min-width: 0;
  }

  .post__content :global(h2),
  .post__content :global(h3),
  .post__content :global(h4) {
    font-family: var(--font-display);
    color: var(--color-text);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 2.5rem 0 0.9rem;
    line-height: 1.15;
  }

  .post__content :global(h2) { font-size: 1.75rem; }
  .post__content :global(h3) { font-size: 1.35rem; }
  .post__content :global(h4) { font-size: 1.1rem; }

  .post__content :global(p) {
    margin: 0 0 1.25rem;
  }

  .post__content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post__content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .post__content :global(ul),
  .post__content :global(ol) {
    padding-left: 1.4rem;
    margin: 0 0 1.4rem;
  }

  .post__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post__content :global(img) {
    display: block;
    width: 100%;
    border-radius: 10px;
    margin: 2rem 0;
    border: 1px solid var(--color-border);
  }

  .post__content :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface);
    color: var(--color-text);
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }

  .post__content :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post__content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-muted-light);
  }

  .post__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }

  .post__content :global(th) {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .post__content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    color: var(--color-muted-light);
  }

  @media (max-width: 768px) {
    .post__hero {
      padding: 4.5rem 1.25rem 2.5rem;
    }

    .post__image-wrap {
      padding: 0 1.25rem;
      margin: 2rem auto;
    }

    .post__image {
      height: 240px;
    }

    .post__body {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.25rem;
    }

    .post__sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar__divider,
    .sidebar__back {
      display: none;
    }
  }
</style>