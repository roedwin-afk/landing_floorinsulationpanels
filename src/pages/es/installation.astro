---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/layout/Footer.astro";
import InstallationPage from "../../components/sections/InstallationPage.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<BaseLayout
  t={t}
  lang={lang}
  title={t.installation.meta.title}
  description={t.installation.meta.description}
>
  <InstallationPage t={t} lang={lang} />
  <Footer t={t} lang={lang} />
</BaseLayout>