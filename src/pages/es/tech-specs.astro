---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TechSpecsPage from "../../components/sections/TechSpecsPage.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<BaseLayout
  t={t}
  lang={lang}
  title={t.techSpecs.meta.title}
  description={t.techSpecs.meta.description}
>
  <TechSpecsPage t={t} lang={lang} />
</BaseLayout>