---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/sections/ContactForm.astro';
import { getLang, useTranslations } from '../../i18n/utils';

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<BaseLayout 
  title="Industrial Floor Insulation"
  description="High-density floor insulation panel systems for industrial warehouses and cold storage facilities."
  t={t} 
  lang={lang}
>
  <main>
      <ContactForm t={t} lang={lang} />
  </main>
</BaseLayout>